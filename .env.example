# Supabase 연결 정보
# Supabase 대시보드 > Project Settings > API 에서 복사
# 실제 값은 .env.local 에 넣으세요 (.env.local 은 git에 커밋되지 않음)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── 아래는 로컬 스크립트 전용 (앱 런타임에는 불필요, 절대 커밋 금지) ──

# 어드민 계정 생성: node scripts/create-admins.mjs  (service_role 키 필요)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ADMIN1_USERNAME=rohji
# ADMIN1_PASSWORD=change-me
# ADMIN1_NAME=노지환
# ADMIN1_WISHLIST_TEAM=lg
# ADMIN2_USERNAME=hwyu
# ADMIN2_PASSWORD=change-me
# ADMIN2_NAME=유혜원
# ADMIN2_WISHLIST_TEAM=samsung

# 거래 E2E 점검: node scripts/_e2e.mjs
# E2E_EMAIL=rohji@gmail.com
# E2E_PASSWORD=change-me
